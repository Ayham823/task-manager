terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

resource "aws_security_group" "task_manager_sg" {
  name        = "task-manager-sg"
  description = "Security group for Task Manager"

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "Django temporary"
    from_port   = 8000
    to_port     = 8000
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_instance" "task_manager_server" {
  ami                    = var.ami_id
  instance_type          = var.instance_type
  key_name               = var.key_name
  vpc_security_group_ids = [aws_security_group.task_manager_sg.id]

  tags = {
    Name = var.instance_name
  }

  provisioner "local-exec" {
    command = <<EOT
      sleep 60
      echo "[web]" > ../ansible/inventory.ini
      echo "${self.public_ip} ansible_user=ubuntu ansible_ssh_private_key_file=/home/win11/.ssh/task-key.pem" >> ../ansible/inventory.ini
      cd ../ansible && ansible-playbook -i inventory.ini setup.yml
    EOT
  }
}